# PostgreSQL (túnel local)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=judge_db
DB_USER=postgres
DB_PASSWORD=

# Google Gemini (juiz multi-modelo) — usado por judge_gemini_service
GEMINI_API_KEY=

# Opcional: paralelismo (default 20)
# JUDGE_MAX_WORKERS=20

# Opcional: limite de tokens da saída do juiz Gemini (default 8192)
# Aumente se o JSON truncar (finish_reason=MAX_TOKENS).
# JUDGE_MAX_OUTPUT_TOKENS=8192

# Opcional: pular BERTScore (desenvolvimento sem torch pesado)
# SKIP_BERT=1

# Logs da API (uvicorn): DEBUG para judge_gemini / runner
# JUDGE_DEBUG_LOG=1

# Incluir traceback truncado nos eventos SSE (visível no painel Progresso do Vue)
# JUDGE_SSE_TRACEBACK=1

# Azure OpenAI (legado; não usado pelo juiz Gemini)
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_CHAT_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=
